import React, { useState } from "react";
import { Coins, CreditCard, ShieldCheck, CheckCircle2, DollarSign, Wallet, ArrowRight, ArrowLeft } from "lucide-react";
import { AppUser } from "../types";
import { motion, AnimatePresence } from "motion/react";

interface BalanceSectionProps {
  currentUser: AppUser | null;
  onCreateBakiyeRequest: (amount: number) => Promise<void>;
}

export default function BalanceSection({
  currentUser,
  onCreateBakiyeRequest
}: BalanceSectionProps) {
  const [selectedAmount, setSelectedAmount] = useState<number>(100);
  const [customAmount, setCustomAmount] = useState<string>("");
  const [isProcessing, setIsProcessing] = useState(false);

  const finalAmount = customAmount ? parseFloat(customAmount) || 0 : selectedAmount;

  const handlePaymentSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (finalAmount <= 0) {
      alert("Lütfen geçerli bir yükleme miktarı belirleyin.");
      return;
    }

    setIsProcessing(true);
    try {
      await onCreateBakiyeRequest(finalAmount);
    } catch (err) {
      alert("Bakiye talebi iletilirken hata oluştu.");
    } finally {
      setIsProcessing(false);
    }
  };

  if (!currentUser) {
    return (
      <div className="glass-card p-10 rounded-2xl border border-dashed border-secondary/30 text-center space-y-4 max-w-lg mx-auto">
        <Coins className="w-12 h-12 text-secondary mx-auto animate-pulse" />
        <h3 className="font-headline-md text-lg font-black text-on-surface">Kredi Yükleme Sistemi</h3>
        <p className="text-xs text-on-surface-variant font-body-md leading-relaxed">
          Hesabınıza bakiye yükleyebilmek ve ayrıcalıklı market paketlerinden yararlanmak için lütfen önce Minecraft kullanıcı adınızla giriş yapınız.
        </p>
      </div>
    );
  }

  return (
    <motion.div
      initial={{ opacity: 0, y: 15 }}
      animate={{ opacity: 1, y: 0 }}
      exit={{ opacity: 0, y: -15 }}
      className="max-w-4xl mx-auto space-y-8 font-sans pb-16 text-left"
    >
      {/* Header */}
      <div>
        <h2 className="font-headline-lg font-extrabold text-on-surface text-3xl tracking-tight">
          Güvenli <span className="text-secondary">Bakiye Satın Al</span>
        </h2>
        <p className="text-xs text-outline font-body-md mt-1">
          SarsılmazMC hesabınıza bakiye ekleyerek dilediğiniz market ögesini ve VIP ayrıcalıklarını anında oyun içinde aktif hale getirin.
        </p>
      </div>

      <AnimatePresence mode="wait">
        <motion.div
          key="payment-flows"
          initial={{ opacity: 0, scale: 0.98 }}
          animate={{ opacity: 1, scale: 1 }}
          exit={{ opacity: 0, scale: 0.98 }}
          className="grid grid-cols-1 lg:grid-cols-12 gap-8"
        >
          {/* LEFT SIDE: AMOUNT SELECTION */}
          <div className="lg:col-span-5 space-y-6">
            <div className="glass-card p-6 rounded-2xl border border-outline-variant/30 space-y-4 bg-[#0a0f12]/60">
              <span className="text-[10px] font-mono text-outline uppercase tracking-wider block font-bold">AŞAMA 1: YÜKLENECEK MİKTAR</span>
              
              {/* Visual view of private wallet balance */}
              <div className="p-4 rounded-xl bg-secondary/5 border border-secondary/20 flex items-center justify-between">
                <div>
                  <span className="text-[10px] font-mono text-outline block">Hesap Bakiyeniz</span>
                  <span className="text-2xl font-black font-mono text-secondary">{currentUser.credits},00 ₺</span>
                </div>
                <Wallet className="w-8 h-8 text-secondary/40" />
              </div>

              {/* Grid of pre-set credit pack selection */}
              <div className="grid grid-cols-2 gap-3 pb-2">
                {[50, 100, 250, 500].map((val) => (
                  <button
                    key={val}
                    type="button"
                    onClick={() => {
                      setSelectedAmount(val);
                      setCustomAmount("");
                    }}
                    className={`py-3 rounded-xl font-mono text-sm font-black transition-all flex flex-col justify-center items-center gap-1 cursor-pointer border ${
                      selectedAmount === val && !customAmount
                        ? "bg-secondary/15 text-secondary border-secondary shadow-[0_0_12px_rgba(254,183,10,0.15)]"
                        : "bg-surface-container-high/40 text-outline border-transparent hover:border-outline-variant/50"
                    }`}
                  >
                    <span>{val},00 ₺</span>
                    <span className="text-[8px] opacity-75 font-sans font-medium uppercase tracking-wider">PAKET SEÇ</span>
                  </button>
                ))}
              </div>

              {/* Custom Amount Field */}
              <div className="space-y-1.5">
                <label className="text-[10px] font-mono text-outline uppercase tracking-wider block">farklı miktar girin (₺)</label>
                <div className="relative">
                  <span className="absolute left-3 top-1/2 -translate-y-1/2 text-outline-variant text-xs font-mono">₺</span>
                  <input
                    type="number"
                    placeholder="Örn: 150"
                    value={customAmount}
                    onChange={(e) => {
                      setCustomAmount(e.target.value);
                      setSelectedAmount(0);
                    }}
                    className="w-full bg-[#080d0f] border border-outline-variant/30 rounded-xl py-3 pl-8 pr-4 font-mono text-xs text-on-surface outline-none focus:border-secondary"
                  />
                </div>
              </div>

              <div className="p-3 bg-surface-container-highest/60 rounded-xl text-[10px] font-mono text-outline leading-relaxed border border-outline-variant/20 border-dashed">
                💡 Bakiye talepleriniz yetkililerimizce onaylandığı an oyun içi cüzdanınıza yansıyacaktır.
              </div>
            </div>
          </div>

          {/* RIGHT SIDE: SECURE SUPPORT NOTIFICATION */}
          <div className="lg:col-span-7 space-y-6">
            <div className="glass-card p-6 md:p-8 rounded-2xl border border-secondary/35 space-y-6 bg-surface-container/60 relative overflow-hidden flex flex-col justify-between">
              <div className="space-y-4 text-left">
                <span className="text-[10px] font-mono text-secondary uppercase tracking-wider block font-bold">AŞAMA 2: TALEP OLUŞTURMA</span>
                
                <h4 className="text-xl font-headline-md font-extrabold text-white flex items-center gap-2">
                  <ShieldCheck className="w-5.5 h-5.5 text-secondary" />
                  Destek Kanalları ile Güvenli Ödeme
                </h4>
                
                <div className="space-y-3 text-xs text-outline font-body-md leading-relaxed">
                  <p>
                    SarsılmazMC portalı üzerinde güvenliğiniz sebebiyle doğrudan kart numarası, şifre ya da IBAN bilgileriniz istenmez.
                  </p>
                  <p>
                    Yukarıda seçtiğiniz miktar olan <strong className="text-secondary">{finalAmount},00 ₺</strong> yüklemesi yapmak için aşağıdaki butona bastığınızda sizin adınıza otomatik bir destek talebi açılacaktır.
                  </p>
                  <p>
                    Açılan talep üzerinden admin ekibimiz size <strong className="text-white">PayTR / Papara Ödeme Linkinizi</strong> yönlendirecektir ve ödemenizi tamamladığınızda bakiyeniz onaylanacaktır.
                  </p>
                </div>

                <div className="mt-2 p-3 bg-secondary/5 border border-secondary/20 rounded-xl font-mono text-[11px] text-secondary">
                  <strong>Mesaj Taslağınız:</strong> <br />
                  &quot;merhaba ben {currentUser.username} {finalAmount} tutarında Bakiye yüklemek istiyorum. Bakiye yükleme Linki atar mısınız ?&quot;
                </div>
              </div>

              <form onSubmit={handlePaymentSubmit} className="pt-4 border-t border-outline-variant/15 flex flex-col sm:flex-row justify-between items-stretch sm:items-center gap-4">
                <div className="text-left">
                  <span className="text-[9px] font-mono text-outline block uppercase">TALEP EDİLEN BAKİYE</span>
                  <span className="text-2xl font-black font-mono text-secondary">{finalAmount},00 ₺</span>
                </div>

                <button
                  type="submit"
                  disabled={isProcessing || finalAmount <= 0}
                  className="px-6 py-3.5 bg-secondary hover:bg-secondary/95 text-on-secondary font-mono text-xs font-black uppercase tracking-wider rounded-xl cursor-pointer shadow-[0_0_15px_rgba(254,183,10,0.3)] hover:scale-105 active:scale-95 transition-all text-center flex items-center justify-center gap-2"
                >
                  {isProcessing ? (
                    <>
                      <Coins className="w-4 h-4 animate-spin text-on-secondary" /> BAĞLANTI KURULUYOR...
                    </>
                  ) : (
                    <>
                      BAKİYE TALEBİ OLUŞTUR <ArrowRight className="w-4 h-4" />
                    </>
                  )}
                </button>
              </form>
            </div>
          </div>
        </motion.div>
      </AnimatePresence>
    </motion.div>
  );
}
