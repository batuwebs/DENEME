import React, { useState } from "react";
import { Ticket, TicketMessage, AppUser } from "../types";
import { 
  Ticket as TicketIcon, 
  MessageSquare, 
  PlusCircle, 
  CheckCheck, 
  RefreshCw, 
  Send, 
  AlertTriangle, 
  Image as ImageIcon, 
  X,
  Info,
  Calendar,
  Clock,
  ShieldCheck,
  UserCheck
} from "lucide-react";
import { motion, AnimatePresence } from "motion/react";

interface SupportSectionProps {
  currentUser: AppUser | null;
  tickets: Ticket[];
  onCreateTicket: (
    subject: string,
    category: "Genel" | "Ödeme" | "Hata Bildirimi" | "Klan İşlemleri",
    initialMessage: string,
    attachment?: string
  ) => Promise<void>;
  onSendMessage: (ticketId: string, text: string, attachment?: string) => Promise<void>;
  onRefreshTickets: () => void;
  isGlobalRefreshing: boolean;
  onDeleteTicket?: (ticketId: string) => Promise<void>;
}

export default function SupportSection({
  currentUser,
  tickets,
  onCreateTicket,
  onSendMessage,
  onRefreshTickets,
  isGlobalRefreshing,
  onDeleteTicket
}: SupportSectionProps) {
  const [activeTicketId, setActiveTicketId] = useState<string | null>(null);
  const [isCreatingTicket, setIsCreatingTicket] = useState(false);

  // New ticket state
  const [subject, setSubject] = useState("");
  const [category, setCategory] = useState<"Genel" | "Ödeme" | "Hata Bildirimi" | "Klan İşlemleri">("Genel");
  const [initialMessage, setInitialMessage] = useState("");
  const [ticketAttachment, setTicketAttachment] = useState<string>("");
  const [isFormSubmitting, setIsFormSubmitting] = useState(false);

  // Message chat input state
  const [replyText, setReplyText] = useState("");
  const [replyAttachment, setReplyAttachment] = useState<string>("");
  const [isSendingReply, setIsSendingReply] = useState(false);

  // Rate Limiter / Cooldown State
  const [writeCooldown, setWriteCooldown] = useState(0);

  // Start rate limiter cooldown timer
  const triggerCooldown = () => {
    setWriteCooldown(5); // 5 seconds cooldown
    const interval = setInterval(() => {
      setWriteCooldown((prev) => {
        if (prev <= 1) {
          clearInterval(interval);
          return 0;
        }
        return prev - 1;
      });
    }, 1000);
  };

  const handleCreateTicketSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!subject.trim() || !initialMessage.trim()) return;

    if (writeCooldown > 0) {
      alert(`Lütfen ${writeCooldown} saniye bekleyin!`);
      return;
    }

    setIsFormSubmitting(true);
    try {
      await onCreateTicket(subject, category, initialMessage, ticketAttachment.trim() || undefined);
      setSubject("");
      setInitialMessage("");
      setTicketAttachment("");
      setIsCreatingTicket(false);
      triggerCooldown();
    } catch (err) {
      console.error(err);
    } finally {
      setIsFormSubmitting(false);
    }
  };

  const handleSendMessageSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    if ((!replyText.trim() && !replyAttachment.trim()) || !activeTicketId) return;

    if (writeCooldown > 0) {
      alert(`Lütfen ${writeCooldown} saniye bekleyin!`);
      return;
    }

    setIsSendingReply(true);
    try {
      await onSendMessage(activeTicketId, replyText, replyAttachment.trim() || undefined);
      setReplyText("");
      setReplyAttachment("");
      triggerCooldown();
    } catch (err) {
      console.error(err);
    } finally {
      setIsSendingReply(false);
    }
  };

  // Find currently active ticket
  const activeTicket = tickets.find((t) => t.id === activeTicketId);

  // Filter user tickets (safety lower-case matching) - admins see all tickets
  const userTickets = tickets.filter(
    (t) => currentUser && (currentUser.role?.toLowerCase() === "admin" || t.user.toLowerCase() === currentUser.username.toLowerCase())
  );

  return (
    <motion.div
      initial={{ opacity: 0, y: 15 }}
      animate={{ opacity: 1, y: 0 }}
      exit={{ opacity: 0, y: -15 }}
      transition={{ duration: 0.3 }}
      className="space-y-8 pb-16 text-left"
    >
      {/* Support Header */}
      <div className="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
          <h2 className="font-headline-lg font-extrabold text-on-surface text-3xl tracking-tight">
            Destek <span className="text-secondary">Merkezi</span>
          </h2>
          <p className="text-xs text-outline font-body-md mt-1">
            Yaşadığınız her türlü teknik arıza veya bakiye yükleme sorununda çözüm ortaklarımızla doğrudan iletişim kurun.
          </p>
        </div>

        <div className="flex gap-2 w-full sm:w-auto">
          {/* Manual cache refresh button */}
          <button
            onClick={onRefreshTickets}
            className={`flex-1 sm:flex-initial px-4 py-2.5 bg-surface-container-high hover:bg-surface-container-highest rounded-xl text-xs font-mono font-bold border border-outline-variant/30 text-on-surface flex items-center justify-center gap-2 cursor-pointer transition-all ${
              isGlobalRefreshing ? "opacity-50" : ""
            }`}
          >
            <RefreshCw className={`w-4 h-4 ${isGlobalRefreshing ? "animate-spin text-secondary" : ""}`} />
            YENİLE
          </button>

          {currentUser && currentUser.role?.toLowerCase() !== "admin" && (
            <button
              onClick={() => {
                setIsCreatingTicket(true);
                setActiveTicketId(null);
                setTicketAttachment("");
              }}
              className="flex-1 sm:flex-initial px-4 py-2.5 bg-secondary hover:bg-secondary/95 text-on-secondary font-mono text-xs font-black rounded-xl cursor-pointer transition-all flex items-center justify-center gap-1.5 shadow-[0_0_12px_rgba(254,183,10,0.2)]"
            >
              <PlusCircle className="w-4 h-4" /> YENİ TALEP
            </button>
          )}
        </div>
      </div>

      {!currentUser ? (
        /* PROMPT SIGN IN */
        <div className="glass-card p-10 rounded-2xl border border-dashed border-secondary/35 text-center space-y-4 max-w-lg mx-auto">
          <TicketIcon className="w-12 h-12 text-secondary mx-auto animate-pulse" />
          <h3 className="font-headline-md text-lg font-black text-on-surface">Destek Sistemi Hatası</h3>
          <p className="text-xs text-on-surface-variant font-body-md leading-relaxed">
            Aktif taleplerinizi incelemek veya teknik ekibe bildiri bırakmak için öncelikle profil alanından Minecraft kullanıcı adınızla giriş yapmalısınız.
          </p>
        </div>
      ) : (isCreatingTicket && currentUser.role?.toLowerCase() !== "admin") ? (
        /* VIEW A: CREATE TICKET FORM + WARM WELCOMING PANEL */
        <motion.div
          initial={{ opacity: 0, scale: 0.98 }}
          animate={{ opacity: 1, scale: 1 }}
          className="max-w-2xl mx-auto space-y-6"
        >
          {/* WARM WELCOMING PANEL - "Destek talebi açarken karşılama gelsin" */}
          <div className="glass-card p-6 rounded-2xl border-2 border-secondary/45 bg-[#17140e] relative overflow-hidden flex flex-col md:flex-row items-start gap-4">
            <div className="absolute top-[-30%] right-[-20%] w-48 h-48 bg-secondary/5 rounded-full blur-2xl pointer-events-none"></div>
            
            <div className="bg-secondary/15 p-2 rounded-xl border border-secondary/40 text-secondary shrink-0">
              <ShieldCheck className="w-6 h-6" />
            </div>

            <div className="space-y-2">
              <h4 className="text-sm font-headline-md font-extrabold text-secondary tracking-tight">
                SarsılmazMC Teknik Destek Merkezine Hoş Geldiniz!
              </h4>
              <p className="text-xs text-on-surface-variant font-sans leading-relaxed">
                Değerli oyuncumuz <strong>{currentUser.username}</strong>, size yardımcı olmaktan memnuniyet duyacağız. 
                Süreçlerin hızlanması ve çözümün netleşmesi için:
                <span className="block mt-1 pl-2 border-l-2 border-secondary/45 italic">
                  • Ödeme sorunlarında mutlaka ödeme yaptığınız yöntem bilgisini ekleyin.<br/>
                  • Hatalarla karşılaştıysanız, ekran görüntüsü yükleme linki (link/URL) koymayı unutmayın.
                </span>
                Talebiniz gönderildikten sonra ortalama 10 dakika içerisinde sistemimiz üzerinden cevaplanacaktır. Teşekkür ederiz!
              </p>
            </div>
          </div>

          {/* CREATE FORM */}
          <form
            onSubmit={handleCreateTicketSubmit}
            className="glass-card p-6 md:p-8 rounded-2xl border border-outline-variant/30 space-y-5"
          >
            <div className="flex justify-between items-center pb-4 border-b border-outline-variant/20">
              <h3 className="font-headline-md text-lg text-on-surface font-extrabold flex items-center gap-2">
                <TicketIcon className="w-5 h-5 text-secondary" /> Talep Oluşturuluyor
              </h3>
              <button
                type="button"
                onClick={() => setIsCreatingTicket(false)}
                className="text-xs font-mono text-outline hover:text-error transition-colors"
              >
                Vazgeç
              </button>
            </div>

            <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div className="md:col-span-2 space-y-1.5">
                <label className="text-[10px] font-mono text-outline uppercase tracking-wider block font-bold">KONU BAŞLIĞI</label>
                <input
                  type="text"
                  required
                  placeholder="Örn: VIP Aktifleşmedi, Oyundan atma sorunu"
                  value={subject}
                  onChange={(e) => setSubject(e.target.value)}
                  className="w-full bg-[#080d0f] border border-outline-variant/30 rounded-xl py-3 px-4 font-mono text-xs text-on-surface outline-none focus:border-secondary transition-all"
                />
              </div>

              <div className="space-y-1.5">
                <label className="text-[10px] font-mono text-outline uppercase tracking-wider block font-bold">KATEGORİ SEÇİN</label>
                <select
                  value={category}
                  onChange={(e) => setCategory(e.target.value as any)}
                  className="w-full bg-[#080d0f] border border-outline-variant/30 rounded-xl py-3 px-3 font-mono text-xs text-on-surface outline-none focus:border-secondary transition-all"
                >
                  <option value="Genel">Genel</option>
                  <option value="Ödeme">Ödeme</option>
                  <option value="Hata Bildirimi">Hata Bildirimi</option>
                  <option value="Klan İşlemleri">Klan İşlemleri</option>
                </select>
              </div>
            </div>

            <div className="space-y-1.5">
              <label className="text-[10px] font-mono text-outline uppercase tracking-wider block font-bold">YAZILI DETAY</label>
              <textarea
                required
                rows={4}
                placeholder="Lütfen durumunuzu detaylıca anlatınız..."
                value={initialMessage}
                onChange={(e) => setInitialMessage(e.target.value)}
                className="w-full bg-[#080d0f] border border-outline-variant/30 rounded-xl py-3 px-4 font-mono text-xs text-on-surface outline-none focus:border-secondary transition-all resize-none"
              />
            </div>

            {/* Link-Based Attachment URL - "Resim yollama ozelligini link ile ayarla" */}
            <div className="space-y-2">
              <label className="text-[10px] font-mono text-outline uppercase tracking-wider block font-bold">
                KANIT/DEKONT RESMİ BAĞLANTISI (IMAGE LINK URL)
              </label>
              
              <div className="relative">
                <span className="absolute left-3.5 top-1/2 -translate-y-1/2 text-outline-variant">
                  <ImageIcon className="w-4 h-4" />
                </span>
                <input
                  type="text"
                  placeholder="https://i.ibb.co/hızlı-resim-veya-ekran-görüntüsü-bağlantısı.png"
                  value={ticketAttachment}
                  onChange={(e) => setTicketAttachment(e.target.value)}
                  className="w-full bg-[#080d0f] border border-outline-variant/30 rounded-xl py-3 pl-10 pr-4 font-mono text-xs text-on-surface outline-none focus:border-secondary transition-all"
                />
              </div>
              <p className="text-[9px] font-mono text-outline italic">
                💡 Doğrudan resim yüklemek yerine, ekran kesitinizi hızlıresim vb. bir servise yükleyip linkini buraya yapıştırabilirsiniz.
              </p>

              {ticketAttachment && ticketAttachment.startsWith("http") && (
                <div className="relative inline-block mt-2 bg-background p-2 rounded-xl border border-outline-variant/30">
                  <p className="text-[10px] text-secondary font-mono mb-1 font-bold">RESİM ÖNİZLEME:</p>
                  <img
                    src={ticketAttachment}
                    alt="Önizleme"
                    referrerPolicy="no-referrer"
                    className="max-h-40 max-w-full rounded-lg object-contain border border-outline-variant/10"
                    onError={() => console.warn("Invalid attached link")}
                  />
                  <button
                    type="button"
                    onClick={() => setTicketAttachment("")}
                    className="absolute top-1 right-1 bg-black/70 hover:bg-black/95 text-white p-1 rounded-full cursor-pointer"
                  >
                    <X className="w-3.5 h-3.5" />
                  </button>
                </div>
              )}
            </div>

            {writeCooldown > 0 && (
              <div className="bg-red-500/10 border border-red-500/30 rounded-xl p-3 text-xs text-error font-body-md">
                Yazma sınırlaması! Lütfen {writeCooldown} saniye bekleyin.
              </div>
            )}

            <button
              type="submit"
              disabled={isFormSubmitting || writeCooldown > 0}
              className={`w-full py-4 rounded-xl font-mono text-xs font-black uppercase tracking-widest text-center transition-all ${
                isFormSubmitting || writeCooldown > 0
                  ? "bg-surface-container-highest text-outline cursor-not-allowed"
                  : "bg-secondary text-on-secondary shadow-[0_0_15px_rgba(254,183,10,0.25)] active:scale-95 cursor-pointer"
              }`}
            >
              {isFormSubmitting ? "TALEP GÖNDERİLİYOR..." : "DESTEK TALEBİNİ RESMEN GÖNDER"}
            </button>
          </form>
        </motion.div>
      ) : (
        /* VIEW B: SUPPORT LIST / INTERACTIVE EXHAUSTIVE CHAT */
        <div className="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
          {/* Ticket Listing Siderail */}
          <div className="lg:col-span-4 space-y-4">
            <h3 className="font-label-caps text-[10px] text-outline px-1 font-bold">DESTEK KAYITLARIM ({userTickets.length})</h3>
            
            {userTickets.length === 0 ? (
              <div className="glass-card p-6 rounded-xl border border-dashed border-outline-variant/30 text-center text-xs text-outline font-mono">
                Hesabınıza bağlı aktif bir destek talebi kaydı bulunmuyor.
              </div>
            ) : (
              <div className="space-y-3 max-h-[60vh] overflow-y-auto custom-scrollbar pr-1">
                {userTickets.map((t) => (
                  <button
                    key={t.id}
                    onClick={() => {
                      setActiveTicketId(t.id);
                      setIsCreatingTicket(false);
                      setReplyAttachment("");
                    }}
                    className={`w-full text-left p-4 rounded-xl border transition-all flex flex-col justify-between cursor-pointer group ${
                      activeTicketId === t.id
                        ? "bg-secondary/10 border-secondary"
                        : "glass-card border-outline-variant/20 hover:border-outline-variant/60"
                    }`}
                  >
                    <div className="flex justify-between items-start gap-4">
                      <div className="space-y-0.5 max-w-[70%]">
                        <span className="font-mono text-[10px] text-outline tracking-wider font-bold">{t.id}</span>
                        <h4 className="font-bold text-sm text-on-surface group-hover:text-secondary transition-colors truncate">
                          {t.subject}
                        </h4>
                      </div>
                      <span
                        className={`px-2.5 py-0.5 rounded-full text-[9px] font-black tracking-wider uppercase border shrink-0 ${
                          t.status === "beklemede"
                            ? "bg-yellow-500/10 text-yellow-400 border-yellow-500/30"
                            : t.status === "yanıtlandı"
                            ? "bg-green-500/10 text-green-400 border-green-500/30"
                            : "bg-outline-variant/10 text-outline border-outline-variant/30"
                        }`}
                      >
                        {t.status === "beklemede" ? "Kuyrukta" : t.status === "yanıtlandı" ? "Cevaplandı" : "Kapatıldı"}
                      </span>
                    </div>

                    <div className="pt-3 mt-3 border-t border-outline-variant/10 flex justify-between items-center text-[10px] font-mono text-outline">
                      <span className="bg-surface-variant/40 px-2 py-0.5 rounded text-outline-variant">{t.category}</span>
                      <span>{new Date(t.updatedAt).toLocaleDateString("tr-TR")}</span>
                    </div>
                  </button>
                ))}
              </div>
            )}
          </div>

          {/* Interactive Chat Canvas */}
          <div className="lg:col-span-8">
            {activeTicket ? (
              <div className="glass-card rounded-2xl border border-secondary/35 bg-[#0b1012]/80 overflow-hidden flex flex-col h-[65vh] shadow-2xl relative">
                {/* Chat header */}
                <div className="bg-surface-container/90 px-4 py-3 border-b border-outline-variant/25 flex items-center justify-between z-10 font-sans">
                  <div className="flex items-center gap-3">
                    <div className="relative">
                      <div className="w-10 h-10 rounded-full bg-secondary/10 flex items-center justify-center border border-secondary/30">
                        <span className="text-secondary text-xs font-black">S</span>
                      </div>
                      <span className="absolute bottom-0 right-0 w-3 h-3 bg-green-500 border-2 border-background rounded-full"></span>
                    </div>
                    <div>
                      <h4 className="text-on-surface font-bold text-sm">Sarsılmaz Destek</h4>
                      <p className="text-[10px] text-secondary font-mono font-bold uppercase tracking-wider">ÇEVRİMİÇİ • {activeTicket.id}</p>
                    </div>
                  </div>

                  <div className="flex items-center gap-2.5">
                    <span className="bg-secondary/15 border border-secondary/30 text-secondary text-[10px] font-mono font-black px-3 py-1 rounded-full uppercase">
                      KATEGORİ: {activeTicket.category.toUpperCase()}
                    </span>

                    {currentUser?.role?.toLowerCase() === "admin" && onDeleteTicket && (
                      <button
                        onClick={async () => {
                          if (confirm("Bu destek talebini veritabanından tamamen silmek istediğinizden emin misiniz?")) {
                            try {
                              await onDeleteTicket(activeTicket.id);
                              setActiveTicketId(null);
                            } catch (err) {
                              alert("Talep silinirken bir hata oluştu.");
                            }
                          }
                        }}
                        className="px-2.5 py-1 bg-red-500/20 hover:bg-red-500/40 border border-red-500/40 text-red-400 hover:text-red-300 rounded-lg text-[10px] font-mono font-black transition-all cursor-pointer uppercase tracking-wider"
                        title="Bu Talebi ve Tüm Mesaj Geçmişini Herkesten Sil"
                      >
                        TALEBİ SİL
                      </button>
                    )}
                  </div>
                </div>

                {/* Messages Feed */}
                <div className="flex-grow overflow-y-auto p-4 md:p-6 space-y-4 custom-scrollbar bg-background/20">
                  <div className="flex justify-center">
                    <span className="px-3 py-1 bg-surface-container-highest/50 rounded-full text-[10px] font-mono font-bold text-outline uppercase tracking-wider">
                      TALEP KAYDI BAŞLATILDI
                    </span>
                  </div>

                  {activeTicket.messages.map((m, idx) => {
                    const isUser = m.sender === "user";
                    return (
                      <div
                        key={idx}
                        className={`flex flex-col max-w-[85%] ${
                          isUser ? "ml-auto items-end text-right" : "mr-auto items-start text-left"
                        }`}
                      >
                        <div
                          className={`p-3.5 rounded-2xl shadow-md border ${
                            isUser
                              ? "bg-secondary-container/10 border-secondary/35 text-on-surface rounded-tr-none text-left"
                              : "bg-surface-container-high/90 border-outline-variant/25 text-on-surface rounded-tl-none text-left"
                          }`}
                        >
                          <p className="text-xs md:text-sm font-sans whitespace-pre-wrap">{m.text}</p>
                          
                          {m.attachment && m.attachment.startsWith("http") && (
                            <div className="mt-3 overflow-hidden rounded-xl border border-outline-variant/30 max-w-sm">
                              <img
                                src={m.attachment}
                                alt="Ekli Resim"
                                referrerPolicy="no-referrer"
                                className="w-full max-h-60 object-contain bg-black/40 cursor-pointer"
                                onClick={() => window.open(m.attachment, "_blank")}
                              />
                            </div>
                          )}

                          <div className={`flex items-center gap-1 mt-1 text-[9px] font-mono text-outline ${isUser ? "justify-end" : "justify-start"}`}>
                            <span>
                              {new Date(m.createdAt).toLocaleTimeString("tr-TR", { hour: "2-digit", minute: "2-digit" })}
                            </span>
                            {isUser && <CheckCheck className="w-3 h-3 text-secondary" />}
                          </div>
                        </div>
                        <span className="text-[9px] font-mono font-bold text-outline-variant mt-1.5 px-1 uppercase tracking-widest">
                          {isUser ? m.senderName : "SARSILMAZ DESTEK EKİBİ"}
                        </span>
                      </div>
                    );
                  })}
                </div>

                {/* Reply Attachment Preview */}
                {replyAttachment && replyAttachment.startsWith("http") && (
                  <div className="bg-[#121b1f] border-t border-secondary/30 p-2 px-4 flex items-center justify-between text-xs font-mono text-secondary">
                    <div className="flex items-center gap-2">
                      <ImageIcon className="w-4 h-4" />
                      <span>Resim linki eklendi (Önizleme hazır)</span>
                    </div>
                    <button onClick={() => setReplyAttachment("")} className="text-error hover:text-white p-1">
                      <X className="w-4 h-4" />
                    </button>
                  </div>
                )}

                {/* Form Chat Input */}
                <div className="p-3 bg-surface-container-high/95 backdrop-blur-md border-t border-outline-variant/20">
                  {activeTicket.status === "kapatıldı" ? (
                    <div className="p-3 rounded-xl border border-outline-variant/25 text-center text-xs text-outline font-mono">
                      🔒 Bu destek kaydı kapatılmıştır. Okuma modundasınız.
                    </div>
                  ) : (
                    <div className="space-y-2">
                      <form onSubmit={handleSendMessageSubmit} className="flex items-center gap-2">
                        <input
                          type="text"
                          placeholder={writeCooldown > 0 ? `Lütfen bekleyin...` : "Cevap yazın..."}
                          value={replyText}
                          onChange={(e) => setReplyText(e.target.value)}
                          disabled={isSendingReply || writeCooldown > 0}
                          className="flex-grow bg-[#0c1214] border border-outline-variant/30 rounded-xl py-2 px-3 focus:border-secondary outline-none text-xs md:text-sm text-on-surface"
                        />
                        <button
                          type="submit"
                          disabled={(!replyText.trim() && !replyAttachment.trim()) || isSendingReply || writeCooldown > 0}
                          className="w-10 h-10 flex items-center justify-center rounded-xl bg-secondary text-on-secondary cursor-pointer hover:scale-105 transition-transform"
                        >
                          <Send className="w-4 h-4" />
                        </button>
                      </form>

                      {/* Attachment image pasting input inside active chat */}
                      <div className="flex items-center gap-2 border-t border-outline-variant/10 pt-2 font-mono">
                        <span className="text-[9px] text-outline shrink-0 block">Ekran Görüntüsü Linki:</span>
                        <input
                          type="text"
                          placeholder="https://i.ibb.co/screenshot.png"
                          value={replyAttachment}
                          onChange={(e) => setReplyAttachment(e.target.value)}
                          className="flex-grow bg-[#070b0c] border border-outline-variant/20 rounded-lg py-1 px-2 text-[10px] text-on-surface focus:border-secondary outline-none"
                        />
                      </div>
                    </div>
                  )}
                </div>
              </div>
            ) : (
              <div className="glass-card h-[60vh] rounded-2xl border border-dashed border-outline-variant/35 flex flex-col items-center justify-center p-8 text-center space-y-4">
                <MessageSquare className="w-12 h-12 text-outline-variant animate-pulse" />
                <h4 className="font-headline-md text-base font-bold text-on-surface">Yazışma Açılmadı</h4>
                <p className="text-xs text-outline font-body-md max-w-sm">
                  Cevapları incelemek ve teknik ekiple canlı görüşmeyi sürdürmek için sol taraftan aktif bir destek kaydı seçin.
                </p>
              </div>
            )}
          </div>
        </div>
      )}
    </motion.div>
  );
}
